# APP_URL: The URL where this application is hosted.
APP_URL="MY_APP_URL"

# CLOUDINARY (For Image Uploads)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your_cloud_name"
NEXT_PUBLIC_CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# MOBILE MONEY API (e.g., Paystack, Hubtel, or MTN MoMo)
# These will be required in later phases for processing payments
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY="YOUR_PAYSTACK_PUBLIC_KEY"
PAYSTACK_SECRET_KEY="YOUR_PAYSTACK_SECRET_KEY"

# EMAIL NOTIFICATIONS (Resend)
RESEND_API_KEY="re_your_resend_api_key"

# EMAIL NOTIFICATIONS (SMTP - Legacy)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="HostelHub <your-email@gmail.com>"

# CRON JOBS
CRON_SECRET="your-cron-secret-key"
