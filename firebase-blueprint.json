{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with role-based access",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "guest", "manager", "admin"] },
        "displayName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "phoneVerified": { "type": "boolean" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["uid", "role"]
    },
    "Hostel": {
      "title": "Hostel",
      "description": "Hostel listing details",
      "type": "object",
      "properties": {
        "managerId": { "type": "string" },
        "name": { "type": "string" },
        "location": { "type": "string" },
        "address": { "type": "string" },
        "distanceFromCampus": { "type": "number" },
        "coordinates": { 
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "amenities": { "type": "array" },
        "images": { "type": "array" },
        "rating": { "type": "number" },
        "isVerified": { "type": "boolean" },
        "policies": { "type": "array" },
        "contactDetails": {
          "type": "object",
          "properties": {
             "phone": { "type" : "string" },
             "email": { "type" : "string" },
             "whatsapp": { "type" : "string" }
          }
        },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["managerId", "name", "location", "address", "createdAt"]
    },
    "Room": {
      "title": "Room",
      "description": "A room inside a hostel",
      "type": "object",
      "properties": {
        "hostelId": { "type": "string" },
        "roomNumber": { "type": "string" },
        "type": { "type": "string" },
        "pricePerSemester": { "type": "number" },
        "capacity": { "type": "number" },
        "occupiedBeds": { "type": "number" },
        "isAvailable": { "type": "boolean" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["hostelId", "roomNumber", "type", "pricePerSemester", "capacity", "occupiedBeds"]
    },
    "Review": {
      "title": "Review",
      "description": "Hostel review by student",
      "type": "object",
      "properties": {
        "hostelId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["hostelId", "userId", "userName", "rating", "comment", "createdAt"]
    },
    "Booking": {
      "title": "Booking",
      "description": "Student booking a room",
      "type": "object",
      "properties": {
        "hostelId": { "type": "string" },
        "hostelName": { "type": "string" },
        "managerId": { "type": "string" },
        "roomId": { "type": "string" },
        "roomNumber": { "type": "string" },
        "studentId": { "type": "string" },
        "studentEmail": { "type": "string" },
        "status": { "type": "string" },
        "amount": { "type": "number" },
        "paymentStatus": { "type": "string" },
        "createdAt": { "type": "string" },
        "expiresAt": { "type": "string" },
        "semester": { "type": "string" },
        "paymentReference": { "type": "string" }
      },
      "required": ["hostelId", "roomId", "studentId", "status", "amount", "paymentStatus", "createdAt"]
    },
    "Complaint": {
      "title": "Complaint",
      "description": "Complaint filed against hostel",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "hostelId": { "type": "string" },
        "managerId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "image": { "type": "string" },
        "status": { "type": "string" },
        "managerResponse": { "type": "string" },
        "adminVisible": { "type": "boolean" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "resolvedAt": { "type": "string" }
      },
      "required": ["userId", "hostelId", "managerId", "title", "message", "status", "createdAt", "updatedAt"]
    },
    "Payout": {
      "title": "Payout",
      "description": "Payout record for manager",
      "type": "object",
      "properties": {
        "managerId": { "type": "string" },
        "amount": { "type": "number" },
        "reference": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["managerId", "amount", "createdAt"]
    },
    "Inquiry": {
      "title": "Inquiry",
      "description": "Student inquiry",
      "type": "object",
      "properties": {
        "hostelId": { "type": "string" },
        "managerId": { "type": "string" },
        "studentName": { "type": "string" },
        "studentEmail": { "type": "string" },
        "senderPhone": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["hostelId", "managerId", "studentName", "studentEmail", "subject", "message", "status", "createdAt"]
    },
    "AppNotification": {
      "title": "AppNotification",
      "description": "Notification",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "actionUrl": { "type": "string" },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "type", "title", "message", "isRead", "createdAt"]
    },
    "ManagerVerification": {
       "title": "ManagerVerification",
       "description": "Manager details for admin verification",
       "type": "object",
       "properties": {
         "userId": { "type": "string" },
         "managerName": { "type": "string" },
         "managerEmail": { "type": "string" },
         "idDocumentUrl": { "type": "string" },
         "propertyProofUrl": { "type": "string" },
         "status": { "type": "string" },
         "submittedAt": { "type": "string" },
         "updatedAt": { "type": "string" },
         "adminNotes": { "type": "string" }
       },
       "required": ["userId", "idDocumentUrl", "propertyProofUrl", "status", "submittedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "User" },
      "description": "User profiles"
    },
    "/hostels/{hostelId}": {
      "schema": { "$ref": "Hostel" },
      "description": "Hostel listings"
    },
    "/hostels/{hostelId}/rooms/{roomId}": {
      "schema": { "$ref": "Room" },
      "description": "Rooms in a hostel"
    },
    "/hostels/{hostelId}/reviews/{reviewId}": {
      "schema": { "$ref": "Review" },
      "description": "Reviews for a hostel"
    },
    "/bookings/{bookingId}": {
       "schema": { "$ref": "Booking" },
       "description": "All bookings"
    },
    "/complaints/{complaintId}": {
       "schema": { "$ref": "Complaint" },
       "description": "Complaints filed"
    },
    "/inquiries/{inquiryId}": {
       "schema": { "$ref": "Inquiry" },
       "description": "Inquiries sent to hoste managers"
    },
    "/payouts/{payoutId}": {
       "schema": { "$ref": "Payout" },
       "description": "Payouts done to managers"
    },
    "/notifications/{notificationId}": {
       "schema": { "$ref": "AppNotification" },
       "description": "Notifications for users"
    },
    "/managerVerifications/{verificationId}": {
       "schema": { "$ref": "ManagerVerification" },
       "description": "Verification submissions"
    }
  }
}
