rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Phase 4: Primitive Definition
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function existing() { return resource.data; }
    function incoming() { return request.resource.data; }
    function isValidId(id) { 
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Role helpers
    function isManager() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager';
    }

    // ==========================================
    // Users Collection
    // ==========================================
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'role', 'createdAt'])
        && data.uid is string && data.uid.size() > 0 && data.uid.size() <= 128
        && data.role is string && (data.role == 'student' || data.role == 'guest' || data.role == 'manager' || data.role == 'admin')
        && data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      
      allow create: if isSignedIn() 
        && request.auth.uid == userId 
        && isValidId(userId)
        && isValidUser(incoming())
        && incoming().uid == request.auth.uid
        && incoming().role != 'admin' // Users cannot self-assign admin role
        && incoming().createdAt == request.time;
      
      allow update: if isSignedIn() 
        && (
          isAdmin() || 
          (
            request.auth.uid == userId 
            && isValidUser(incoming())
            && incoming().uid == existing().uid
            && incoming().role == existing().role // Keep role immutable
            && incoming().createdAt == existing().createdAt
          )
        );
      
      allow delete: if isAdmin();
    }

    // ==========================================
    // Hostels Collection
    // ==========================================
    function isValidHostel(data) {
      return data.keys().hasAll(['managerId', 'name', 'location', 'address', 'createdAt'])
        && data.managerId is string && data.managerId.size() > 0 && data.managerId.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.location is string && data.location.size() > 0 && data.location.size() <= 200
        && data.address is string && data.address.size() > 0 && data.address.size() <= 500
        && data.createdAt is timestamp;
    }

    match /hostels/{hostelId} {
      allow get: if true; // Publicly viewable
      allow list: if true; // Publicly viewable

      allow create: if isManager() 
        && isValidId(hostelId)
        && isValidHostel(incoming())
        && incoming().managerId == request.auth.uid
        && incoming().createdAt == request.time;

      allow update: if isValidId(hostelId) && (isAdmin() || (
        isManager() 
        && existing().managerId == request.auth.uid 
        && isValidHostel(incoming())
        && incoming().managerId == existing().managerId 
        && incoming().createdAt == existing().createdAt 
      ));

      allow delete: if isAdmin() || (isManager() && existing().managerId == request.auth.uid);

      // ==========================================
      // Rooms Subcollection
      // ==========================================
      function isValidRoom(data) {
        return data.keys().hasAll(['hostelId', 'roomNumber', 'type', 'pricePerSemester', 'capacity', 'occupiedBeds'])
          && data.hostelId is string && data.hostelId.size() > 0 && data.hostelId.size() <= 128
          && data.roomNumber is string && data.roomNumber.size() > 0 && data.roomNumber.size() <= 100
          && data.type is string && data.type.size() > 0 && data.type.size() <= 100
          && data.pricePerSemester is number
          && data.capacity is number
          && data.occupiedBeds is number;
      }

      match /rooms/{roomId} {
        allow get: if true;
        allow list: if true;

        allow create: if isValidId(hostelId) && isValidId(roomId) && (isAdmin() || (
          isManager() 
          && get(/databases/$(database)/documents/hostels/$(hostelId)).data.managerId == request.auth.uid
          && isValidRoom(incoming())
          && incoming().hostelId == hostelId
        ));

        allow update: if isValidId(hostelId) && isValidId(roomId) && (isAdmin() || (
          isManager() 
          && get(/databases/$(database)/documents/hostels/$(hostelId)).data.managerId == request.auth.uid
          && isValidRoom(incoming())
          && incoming().hostelId == existing().hostelId
        ) || (
          // Allow system updates via client if needed? E.g., adding occupied beds. Better to do it via transactions
          // We will strictly allow users to increment occupiedBeds only if they're making a booking... wait, atomic transactions handled by service.
          // Since the client directly hits Firestore for bookings, the student runs a transaction.
          isSignedIn() 
          && incoming().diff(existing()).affectedKeys().hasOnly(['occupiedBeds', 'isAvailable'])
          && incoming().occupiedBeds is number
          // && incoming().occupiedBeds <= existing().capacity
        ));

        allow delete: if isValidId(hostelId) && isValidId(roomId) && (isAdmin() || (
          isManager() 
          && get(/databases/$(database)/documents/hostels/$(hostelId)).data.managerId == request.auth.uid
        ));
      }

      // ==========================================
      // Reviews Subcollection
      // ==========================================
      function isValidReview(data) {
        return data.keys().hasAll(['hostelId', 'userId', 'userName', 'rating', 'comment', 'createdAt'])
          && data.hostelId is string && data.hostelId.size() > 0 && data.hostelId.size() <= 128
          && data.userId is string && data.userId.size() > 0 && data.userId.size() <= 128
          && data.userName is string && data.userName.size() > 0 && data.userName.size() <= 200
          && data.rating is number && data.rating >= 1 && data.rating <= 5
          && data.comment is string && data.comment.size() >= 0 && data.comment.size() <= 2000
          && data.createdAt is timestamp;
      }

      match /reviews/{reviewId} {
        allow get: if true;
        allow list: if true;

        allow create: if isSignedIn()
          && isValidId(hostelId) && isValidId(reviewId)
          && isValidReview(incoming())
          && incoming().hostelId == hostelId
          && incoming().userId == request.auth.uid
          && incoming().createdAt == request.time;
          
        allow update: if false; // Reviews cannot be updated
        allow delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
      }
    }

    // ==========================================
    // Bookings Collection
    // ==========================================
    function isValidBooking(data) {
      return data.keys().hasAll(['hostelId', 'roomId', 'studentId', 'status', 'amount', 'paymentStatus', 'createdAt'])
        && data.hostelId is string && data.hostelId.size() > 0 && data.hostelId.size() <= 128
        && data.roomId is string && data.roomId.size() > 0 && data.roomId.size() <= 128
        && data.studentId is string && data.studentId.size() > 0 && data.studentId.size() <= 128
        && data.status is string && (data.status == 'pending' || data.status == 'approved' || data.status == 'confirmed' || data.status == 'cancelled')
        && data.amount is number
        && data.paymentStatus is string && (data.paymentStatus == 'pending' || data.paymentStatus == 'paid' || data.paymentStatus == 'cancelled')
        && data.createdAt is timestamp;
    }

    match /bookings/{bookingId} {
      allow get: if isSignedIn() && (isAdmin() || existing().studentId == request.auth.uid || (existing().managerId != null && existing().managerId == request.auth.uid));
      allow list: if isSignedIn() && (isAdmin() || resource.data.studentId == request.auth.uid || (resource.data.managerId != null && resource.data.managerId == request.auth.uid));

      allow create: if isSignedIn()
        && isValidId(bookingId)
        && isValidBooking(incoming())
        && incoming().studentId == request.auth.uid
        && incoming().createdAt == request.time
        && exists(/databases/$(database)/documents/hostels/$(incoming().hostelId)/rooms/$(incoming().roomId));
      
      allow update: if isValidId(bookingId) && (isAdmin() || (
        isSignedIn() && existing().studentId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'paymentStatus', 'paymentReference', 'updatedAt'])
      ) || (
        isManager() && existing().managerId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])
      ));
      
      allow delete: if isAdmin();
    }

    // ==========================================
    // Complaints Collection
    // ==========================================
    function isValidComplaint(data) {
      return data.keys().hasAll(['userId', 'hostelId', 'managerId', 'title', 'message', 'status', 'createdAt', 'updatedAt'])
        && data.userId is string && data.userId.size() > 0 && data.userId.size() <= 128
        && data.hostelId is string && data.hostelId.size() > 0 && data.hostelId.size() <= 128
        && data.managerId is string && data.managerId.size() > 0 && data.managerId.size() <= 128
        && data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.message is string && data.message.size() > 0 && data.message.size() <= 2000
        && data.status is string && (data.status == 'pending' || data.status == 'in-progress' || data.status == 'resolved')
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    match /complaints/{complaintId} {
      allow get: if isSignedIn() && (isAdmin() || existing().userId == request.auth.uid || existing().managerId == request.auth.uid);
      allow list: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid || resource.data.managerId == request.auth.uid);

      allow create: if isSignedIn()
        && isValidId(complaintId)
        && isValidComplaint(incoming())
        && incoming().userId == request.auth.uid
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;

      allow update: if isValidId(complaintId) && (isAdmin() || (
        isManager() 
        && existing().managerId == request.auth.uid
        && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'managerResponse', 'updatedAt', 'resolvedAt'])
        && incoming().updatedAt == request.time
      ) || (
        isSignedIn()
        && existing().userId == request.auth.uid
        && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])
        && incoming().updatedAt == request.time
      ));

      allow delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
    }

    // ==========================================
    // Inquiries Collection
    // ==========================================
    function isValidInquiry(data) {
      return data.keys().hasAll(['hostelId', 'managerId', 'studentName', 'studentEmail', 'subject', 'message', 'status', 'createdAt'])
        && data.hostelId is string && data.hostelId.size() > 0 && data.hostelId.size() <= 128
        && data.managerId is string && data.managerId.size() > 0 && data.managerId.size() <= 128
        && data.studentName is string && data.studentName.size() > 0 && data.studentName.size() <= 200
        && data.studentEmail is string && data.studentEmail.size() > 0 && data.studentEmail.size() <= 200
        && data.subject is string && data.subject.size() > 0 && data.subject.size() <= 200
        && data.message is string && data.message.size() > 0 && data.message.size() <= 2000
        && data.status is string && (data.status == 'unread' || data.status == 'read' || data.status == 'replied')
        && data.createdAt is timestamp;
    }

    match /inquiries/{inquiryId} {
      allow get: if isSignedIn() && (isAdmin() || existing().managerId == request.auth.uid || existing().studentEmail == request.auth.token.email);
      allow list: if isSignedIn() && (isAdmin() || resource.data.managerId == request.auth.uid);

      allow create: if isValidId(inquiryId)
        && isValidInquiry(incoming())
        && incoming().createdAt == request.time;

      allow update: if isValidId(inquiryId) && (isAdmin() || (
        isManager() 
        && existing().managerId == request.auth.uid
        && incoming().diff(existing()).affectedKeys().hasOnly(['status'])
      ));

      allow delete: if isAdmin();
    }

    // ==========================================
    // Payouts Collection
    // ==========================================
    function isValidPayout(data) {
      return data.keys().hasAll(['managerId', 'amount', 'createdAt'])
        && data.managerId is string && data.managerId.size() > 0 && data.managerId.size() <= 128
        && data.amount is number
        && data.createdAt is timestamp;
    }

    match /payouts/{payoutId} {
      allow get: if isSignedIn() && (isAdmin() || existing().managerId == request.auth.uid);
      allow list: if isSignedIn() && (isAdmin() || resource.data.managerId == request.auth.uid);

      allow create: if isAdmin()
        && isValidId(payoutId)
        && isValidPayout(incoming())
        && incoming().createdAt == request.time;

      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ==========================================
    // Notifications Collection
    // ==========================================
    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'type', 'title', 'message', 'isRead', 'createdAt'])
        && data.userId is string && data.userId.size() > 0 && data.userId.size() <= 128
        && data.type is string && data.type.size() > 0 && data.type.size() <= 50
        && data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.message is string && data.message.size() > 0 && data.message.size() <= 2000
        && data.isRead is bool
        && data.createdAt is timestamp;
    }

    match /notifications/{notificationId} {
      allow get: if isSignedIn() && (isAdmin() || existing().userId == request.auth.uid);
      allow list: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);

      // System generated notifications mostly, but client uses `addDoc`
      allow create: if isSignedIn()
        && isValidId(notificationId)
        && isValidNotification(incoming())
        && incoming().createdAt == request.time;

      allow update: if isValidId(notificationId) && (isAdmin() || (
        isSignedIn()
        && existing().userId == request.auth.uid
        && incoming().diff(existing()).affectedKeys().hasOnly(['isRead'])
      ));

      allow delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
    }

    // ==========================================
    // ManagerVerifications Collection
    // ==========================================
    function isValidManagerVerification(data) {
      return data.keys().hasAll(['userId', 'idDocumentUrl', 'propertyProofUrl', 'status', 'submittedAt'])
        && data.userId is string && data.userId.size() > 0 && data.userId.size() <= 128
        && data.idDocumentUrl is string && data.idDocumentUrl.size() > 0 && data.idDocumentUrl.size() <= 1000
        && data.propertyProofUrl is string && data.propertyProofUrl.size() > 0 && data.propertyProofUrl.size() <= 1000
        && data.status is string && (data.status == 'pending' || data.status == 'verified' || data.status == 'rejected')
        && data.submittedAt is timestamp;
    }

    match /managerVerifications/{verificationId} {
      allow get: if isSignedIn() && (isAdmin() || existing().userId == request.auth.uid);
      allow list: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);

      allow create: if isSignedIn()
        && isValidId(verificationId)
        && isValidManagerVerification(incoming())
        && incoming().userId == request.auth.uid
        && incoming().submittedAt == request.time;

      allow update: if isValidId(verificationId) && (isAdmin() || (
        isSignedIn()
        && existing().userId == request.auth.uid
        && incoming().diff(existing()).affectedKeys().hasOnly(['idDocumentUrl', 'propertyProofUrl', 'updatedAt'])
      ));

      allow delete: if isAdmin();
    }
  }
}
